---
import { Icon } from "astro-icon/components";

// icon = string ""
const services = [
    {
        icon: "portfolio",
        title: "Experiencia comprobada",
        description: `Años de trabajo en diseño web, y desarrollo digital respaldan cada proyecto que realizamos.`,
    },
    {
        icon: "brush-2",
        title: "Soluciones personalizado",
        description: `No creemos en fórmulas genéricas. Cada sitio web que creamos se adapta a las necesidades específicas de tu negocio.`,
    },
    {
        icon: "customer",
        title: "Clientes reales",
        description: `Trabajamos con personas y empresas auténticas, con resultados tangibles que puedes ver en nuestro portafolio.`,
    },
    {
        icon: "chain",
        title: "Enfoque integral",
        description: `Desde la identidad visual hasta el SEO, cubrimos todo el ciclo digital para que tu presencia online sea sólida.`,
    },
    {
        icon: "medal",
        title: "Calidad garantizada",
        description: `Aplicamos procesos de QA Testing para asegurar que cada entrega funcione de manera óptima y sin errores.`,
    },
    {
        icon: "chat",
        title: "Comunicación clara",
        description: `Te acompañamos en cada etapa con transparencia, explicaciones sencillas y soporte constante.`,
    },
];
---

<section
    class="lg:max-w-7xl h-fit mx-auto flex flex-col md:items-center relative text-gray-600 body-font"
>
    <div
        class=`w-full flex flex-col md:flex-row md:gap-20  mx-auto pt-10 px-6 md:px-14 items-center relative z-10`
    >
        <div
            class="md:w-2/3 flex flex-col md:justify-center md:items-start md:text-left md:mb-0 items-start text-start"
        >
            <span
                class="text-[1em] bg-indigo-100 px-3 py-1 rounded-2xl font-medium"
                >Consectetur adipiscing</span
            >
            <h2
                class="title-font capitalize sm:text-4xl lg:text-6xl md:text-4xl text-3xl mb-4 pt-5 font-medium text-(--color-secundary)"
            >
                6
                <span class="text-(--color-brand)">Rasones </span> para escoger <br
                /> nuestros servicios
            </h2>
        </div>
        <div class="md:w-1/3 flex md:justify-end items-center">
            <a
                class="inline-flex text-white bg-(--color-brand) border-0 py-2 px-6 focus:outline-none hover:bg-indigo-600 rounded text-lg"
                >ipsum. Praesent ma</a
            >
        </div>
    </div>
    <!-- ---- services --- -->
    <div
        class="w-full grid md:grid-cols-3 grid-cols-1 gap-5 md:gap-8 py-10 px-6 md:px-14"
    >
        {
            services.map((service) => {
                return (
                    <section class="flex flex-col gap-2 p-8 bg-indigo-100 rounded-2xl">
                        <Icon
                            name={
                                service.icon === "" ? "star" : `${service.icon}`
                            }
                            size={100}
                            class="p-5 bg-white rounded-2xl text-(--color-brand)"
                        />

                        <h2 class="capitalize text-2xl font-medium">
                            {service.title}
                        </h2>
                        <p class="">{service.description}</p>
                    </section>
                );
            })
        }
    </div>
</section>

<style>
    :root {
        /* Ajusta según tu paleta */
        /* --color-brand: #e63946; Color destacado */
    }
    h2.title-font {
        font-family: "Segoe UI", sans-serif;
        font-weight: 500;
        text-transform: capitalize;
        margin-bottom: 1rem;
        padding-top: 1.25rem;
        color: var(--color-secundary);
        line-height: 1.2;
    }
    h2.title-font span {
        color: var(--color-brand);
    } /* Tamaños responsivos */
    @media (max-width: 640px) {
        h2.title-font {
            font-size: 1.875rem; /* sm:text-3xl */
        }
    }
    @media (min-width: 641px) and (max-width: 768px) {
        h2.title-font {
            font-size: 2.25rem; /* md:text-4xl */
        }
    }
    @media (min-width: 769px) and (max-width: 1024px) {
        h2.title-font {
            font-size: 2.25rem; /* lg:text-4xl */
        }
    }
    @media (min-width: 1025px) {
        h2.title-font {
            font-size: 3.75rem; /* xl:text-6xl */
        }
    }
</style>
