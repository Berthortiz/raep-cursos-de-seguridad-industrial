---
// src/pages/servicios.astro
const services = [
    {
        icon: "🌐",
        title: "Creación de Páginas web",
        description:
            "Creación de sitios web informativos y portafolios profesionales 💼. Perfecto para mostrar tu trabajo...",
        btnUrl: "#",
    },
    {
        icon: "🚀",
        title: "Optimización SEO",
        description:
            "Mejora el posicionamiento de tu web en Google y reduce los tiempos de carga al máximo.",
        btnUrl: "#",
    },
    {
        icon: "🛍️",
        title: "Tiendas Online",
        description:
            "Lleva tu negocio al siguiente nivel con una tienda virtual completa y pagos seguros.",
        btnUrl: "#",
    },
];
---

<section class="relative bg-black overflow-hidden py-16 lg:py-24">
    <div
        class="stardust absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 rotate-[-7deg] z-0 scale-x-[2.5] scale-y-[4.2] rounded-full mask-radial-gradient h-56 md:h-80 lg:h-96 w-full pointer-events-none opacity-80"
    >
    </div>

    <div
        class="grid grid-cols-1 md:grid-cols-3 gap-6 px-6 lg:max-w-7xl mx-auto relative z-10"
    >
        {
            services.map((service) => (
                <div class="px-10 py-14 rounded-lg border border-zinc-500/20 backdrop-blur-3xl bg-zinc-500/5 flex flex-col items-center text-center gap-4 hover:border-zinc-500/40 transition-all duration-300 group">
                    <p class="text-6xl mb-2 group-hover:scale-110 transition-transform duration-300">
                        {service.icon}
                    </p>
                    <h3 class="text-xl font-semibold text-white">
                        {service.title}
                    </h3>
                    <p class="text-gray-400 text-[15px] leading-relaxed">
                        {service.description}
                    </p>
                    <a
                        href={service.btnUrl}
                        class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition-colors mt-auto font-medium"
                    >
                        Contactar
                    </a>
                </div>
            ))
        }
    </div>
</section>

<style>
    .mask-radial-gradient {
        -webkit-mask-image: radial-gradient(
            rgba(0, 0, 0, 0.8) 0%,
            rgba(0, 0, 0, 0.79) 5.64%,
            rgba(0, 0, 0, 0.761) 10.6%,
            rgba(0, 0, 0, 0.717) 14.9%,
            rgba(0, 0, 0, 0.66) 18.7%,
            rgba(0, 0, 0, 0.593) 22.2%,
            rgba(0, 0, 0, 0.518) 25.4%,
            rgba(0, 0, 0, 0.44) 28.5%,
            rgba(0, 0, 0, 0.36) 31.5%,
            rgba(0, 0, 0, 0.282) 34.6%,
            rgba(0, 0, 0, 0.207) 37.8%,
            rgba(0, 0, 0, 0.14) 41.3%,
            rgba(0, 0, 0, 0.083) 45.1%,
            rgba(0, 0, 0, 0.039) 49.4%,
            rgba(0, 0, 0, 0.01) 54.36%,
            rgba(0, 0, 0, 0) 60%
        );
        mask-image: radial-gradient(
            rgba(0, 0, 0, 0.8) 0%,
            rgba(0, 0, 0, 0.79) 5.64%,
            rgba(0, 0, 0, 0.761) 10.6%,
            rgba(0, 0, 0, 0.717) 14.9%,
            rgba(0, 0, 0, 0.66) 18.7%,
            rgba(0, 0, 0, 0.593) 22.2%,
            rgba(0, 0, 0, 0.518) 25.4%,
            rgba(0, 0, 0, 0.44) 28.5%,
            rgba(0, 0, 0, 0.36) 31.5%,
            rgba(0, 0, 0, 0.282) 34.6%,
            rgba(0, 0, 0, 0.207) 37.8%,
            rgba(0, 0, 0, 0.14) 41.3%,
            rgba(0, 0, 0, 0.083) 45.1%,
            rgba(0, 0, 0, 0.039) 49.4%,
            rgba(0, 0, 0, 0.01) 54.36%,
            rgba(0, 0, 0, 0) 60%
        );
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
    }

    .stardust {
        background: radial-gradient(
            circle at center,
            rgba(59, 130, 246, 0.6) 0%,
            rgba(37, 99, 235, 0.3) 30%,
            rgba(29, 78, 216, 0.1) 60%,
            transparent 100%
        );
        filter: blur(20px);
    }
</style>
