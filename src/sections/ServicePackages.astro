---
import { Icon } from "astro-icon/components";

// icon = string ""
const services = [
    {
        label: "Sitio web",
        icon: "portfolio",
        title: "Creación web moderna para tu presencia digita",
        description: `Diseñamos sitios web responsivos y optimizados que reflejan la esencia de tu marca.`,
    },
    {
        label: "mantenimiento web",
        icon: "brush-2",
        title: "Mantenimiento para sitios seguros y actualizados",
        description: `Nos encargamos de mantener tu web protegida, y lista para crecer junto a tu negocio.`,
    },
    {
        label: "Web a medida",
        icon: "customer",
        title: "Proyectos web a medida según tus objetivos",
        description: `Creamos soluciones personalizadas que se adaptan a tus necesidades y potencian tu estrategia digital.`,
    },
    {
        label: "Merketing",
        icon: "customer",
        title: "Marketing digital estratégico para atraer clientes reales",
        description: `Campañas de SEO, redes sociales y publicidad online diseñadas para aumentar tu visibilidad y generar tráfico cualificado.
`,
    },
    {
        label: "Merketing",
        icon: "customer",
        title: "Marketing digital estratégico para atraer clientes reales",
        description: `Campañas de SEO, redes sociales y publicidad online diseñadas para aumentar tu visibilidad y generar tráfico cualificado.
`,
    },
    {
        label: "Merketing",
        icon: "customer",
        title: "Marketing digital estratégico para atraer clientes reales",
        description: `Campañas de SEO, redes sociales y publicidad online diseñadas para aumentar tu visibilidad y generar tráfico cualificado.
`,
    },
];
---

<section
    class="lg:max-w-7xl h-fit mx-auto flex flex-col md:items-center relative text-gray-600 body-font"
>
    <div
        class=`w-full flex flex-col md:flex-row md:gap-20  mx-auto pt-10 px-6 md:px-14 items-center relative z-10`
    >
        <div
            class="md:w-3/4 flex flex-col md:justify-center md:items-start md:text-left md:mb-0 items-start text-start"
        >
            <span
                class="text-[1em] bg-indigo-100 px-3 py-1 rounded-2xl font-medium"
                >Consectetur adipiscing</span
            >
            <h2
                class="title-font sm:text-4xl lg:text-5xl md:text-4xl text-3xl mb-4 pt-5 font-medium text-(--color-secundary)"
            >
                <span class="text-(--color-brand)">Paquetes </span>para cubrir
                todas las necesidades digitales de tu negocio
            </h2>
        </div>
        <div class="md:w-1/4 flex md:justify-end items-center"></div>
    </div>
    <!-- ---- services --- -->
    <div
        class="w-full grid md:grid-cols-3 grid-cols-1 gap-5 md:gap-8 py-10 px-6 md:px-14"
    >
        {
            services.map((service) => {
                return (
                    <section class="flex flex-col  gap-4 p-10 bg-indigo-100 rounded-2xl">
                        <Icon
                            name={
                                service.icon === "" ? "star" : `${service.icon}`
                            }
                            size={100}
                            class="p-5 bg-white rounded-2xl text-(--color-brand)"
                        />
                        <span class="w-fit capitalize text-[1em] px-3 py-1 rounded-2xl border-[0.1rem] bg-white  border-indigo-100 text-(--color-brand) font-medium">
                            {service.label}
                        </span>

                        <h2 class="text-[1.3em] font-medium capitalize">
                            {service.title}
                        </h2>
                        <p class="">{service.description}</p>

                        <a class="w-fit text-white bg-(--color-brand) border-0 py-2 px-6 focus:outline-none hover:bg-indigo-600 rounded text-lg">
                            Contact
                        </a>
                    </section>
                );
            })
        }
    </div>
</section>
