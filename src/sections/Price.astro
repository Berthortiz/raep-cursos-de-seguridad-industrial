---
import { Icon } from "astro-icon/components";
import IconCheck from "../components/Icons/IconCheck.astro";

// icon = string ""
const services = [
    {
        icon: "portfolio",
        title: "Basico",
        description: `Años de trabajo en diseño web, y desarrollo digital`,
        features: [
            "Hosting y tu Dominio.com",
            "Diseño responsivo, móviles y tablets.",
            "Plantilla optimizada para carga rápida.",
            "Secciones esenciales: inicio, servicios, contacto.",
            "Integración básica con redes sociales.",
            "Configuración inicial de SEO para visibilidad en buscadores",
        ],
    },
    {
        icon: "brush-2",
        title: "Sitio Personalizado",
        description: `Cada sitio web que creamos se adapta a tu negocio.`,
        features: [
            "Diseño único adaptado a la identidad de tu marca.",
            "Paleta de colores, tipografías y estilo visual propio.",
            "Funcionalidades específicas según tus necesidades (formularios, galerías, etc.).",
            "Copywriting y contenido ajustado a tu tono de comunicación.",
            "Optimización avanzada de SEO y experiencia de usuario.",
        ],
    },
    {
        icon: "customer",
        title: "Web a Medida",
        description: `Trabajamos con personas y empresas auténticas`,
        features: [
            "Desarrollo totalmente desde cero, sin depender de plantillas.",
            "Arquitectura flexible y escalable para crecer con tu negocio.",
            "Integraciones avanzadas como e-commerce, reservas o APIs externas.",
            "Flujos de usuario diseñados estratégicamente para maximizar conversiones.",
            "QA Testing completo para garantizar rendimiento, seguridad y estabilidad.",
        ],
    },
];
---

<section
    class="lg:max-w-7xl h-fit mx-auto flex flex-col md:items-center relative text-gray-600 body-font"
>
    <div
        class=`w-full flex flex-col md:flex-row md:gap-20  mx-auto pt-10 px-6 md:px-14 items-center relative z-10`
    >
        <div
            class="md:w-2/3 flex flex-col md:justify-center md:items-start md:text-left md:mb-0 items-start text-start"
        >
            <span
                class="text-[1em] bg-indigo-100 px-3 py-1 rounded-2xl font-medium"
                >Consectetur adipiscing</span
            >
            <h2
                class="title-font capitalize sm:text-4xl lg:text-5xl md:text-4xl text-3xl mb-4 pt-5 font-medium text-(--color-secundary)"
            >
                <span class="text-(--color-brand)">Empieza hoy. </span> Elige el paquete
                que mejor se adapte a tus necesidades
            </h2>
        </div>
        <div class="md:w-1/3 flex md:justify-end items-center">
            <a
                class="inline-flex text-white bg-(--color-brand) border-0 py-2 px-6 focus:outline-none hover:bg-indigo-600 rounded text-lg"
                >ipsum. Praesent ma</a
            >
        </div>
    </div>
    <!-- ---- services --- -->
    <div
        class="w-full grid md:grid-cols-3 grid-cols-1 gap-5 md:gap-8 py-10 px-6 md:px-14"
    >
        {
            services.map((service) => {
                return (
                    <section class="flex flex-col justify-between capitalize gap-10 px-10 py-16 bg-(--color-brand) text-indigo-50 rounded-2xl">
                        <div class="gap-7 flex flex-col ">
                            <span class="text-5xl font-medium ">$29/Mes </span>
                            <h2 class="text-3xl font-medium">
                                {service.title}
                            </h2>
                            <p class="">{service.description}</p>

                            <ul class="flex flex-col gap-4 text-[1.1em]">
                                {service.features.map((feature) => {
                                    return (
                                        <li class="flex gap-3">
                                            <span class="color-white mt-1">
                                                <IconCheck size={18} />
                                            </span>
                                            <div>
                                                <spam class="font-medium text-[1rem]">
                                                    {feature}
                                                </spam>
                                            </div>
                                        </li>
                                    );
                                })}
                            </ul>
                        </div>
                        <a class="inline-flex justify-center text-(--color-brand) font-bold bg-indigo-50 border-0 py-2 px-6 focus:outline-none hover:bg-indigo-600 rounded text-lg">
                            Cotizar Ahora
                        </a>
                    </section>
                );
            })
        }
    </div>
</section>
