---
import ButtonWithIcon from "./ButtonWithIcon.astro";

const projects = [
    {
        id: 1,
        name_proyect: "Landing Page Corporativa",
        image: "/images/landing.png",
        description: "Página corporativa con diseño moderno y responsive.",
        technologies: [
            { name: "Astro", icon: "/icons/astro.svg" },
            { name: "TailwindCSS", icon: "/icons/tailwind.svg" },
        ],
        buttons: [
            {
                name: "Ver Demo",
                link: "https://demo.com",
                icon: "/icons/demo.svg",
            },
            {
                name: "Repositorio",
                link: "https://github.com/demo",
                icon: "/icons/github.svg",
            },
        ],
    },
];
---

<article id="proyects">
    <h2>Proyectos Web que He Creado</h2>
    <p>Estas páginas han sido creadas por mí para algunos de mis clientes</p>

    <div>
        {
            projects.map((item) => (
                <section class="flex flex-col pb-12 lg:flex-row lg:w-full lg:gap-10">
                    <div class="w-full flex justify-center rounded-2xl overflow-hidden lg:w-[50%]">
                        <img
                            src={item.image}
                            alt={item.name_proyect}
                            class="w-full object-contain"
                        />
                    </div>

                    <div class="w-full text-left flex flex-col gap-2 pt-3.5 p-3 lg:w-[50%]">
                        <h2 class="text-[20px] font-bold text-gray-300 lg:text-3xl">
                            {item.name_proyect}
                        </h2>

                        <ul class="flex flex-wrap gap-x-2">
                            <li>Creada con:</li>
                            {item.technologies.map((tech) => (
                                <li class="flex items-center gap-2">
                                    <p>{tech.name}</p>
                                    <img src={tech.icon} alt={tech.name} />
                                </li>
                            ))}
                        </ul>

                        <p class="text-gray-300">{item.description}</p>

                        <div class="flex gap-4 pt-3">
                            {item.buttons.map((btn) => (
                                <ButtonWithIcon
                                    link={btn.link}
                                    icon={btn.icon}
                                    text={btn.name}
                                />
                            ))}
                        </div>
                    </div>
                </section>
            ))
        }
    </div>
</article>
